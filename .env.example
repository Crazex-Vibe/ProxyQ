# ProxyQ environment configuration
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────
# URL of the server ProxyQ should protect
PROXYQ_ORIGIN=http://your-server:8080

# ── Ports ─────────────────────────────────────────────────
PROXYQ_PORT=3000               # public-facing proxy port
PROXYQ_WS_PORT=3001            # WebSocket port (used internally)
PROXYQ_DASHBOARD_PORT=3002     # admin dashboard port

# Public WebSocket URL (what browsers connect to)
# Change this to your domain in production
PROXYQ_WS_URL=ws://localhost:3001

# ── Queue tuning ──────────────────────────────────────────
# Max simultaneous users allowed on origin at once
# Rule of thumb: set to how many concurrent users your server handles comfortably
PROXYQ_MAX_CONCURRENT=100

# How many users to admit per tick
PROXYQ_ADMIT_PER_INTERVAL=10

# Tick rate in milliseconds
PROXYQ_INTERVAL_MS=2000

# ── Security ──────────────────────────────────────────────
# Admin dashboard token — change this before deploying!
PROXYQ_ADMIN_TOKEN=changeme

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
