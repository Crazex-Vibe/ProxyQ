{
  "name": "proxyq-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start":     "node packages/cli/src/cli.js start --dashboard",
    "dev":       "node --watch packages/cli/src/cli.js start --dashboard",
    "status":    "node packages/cli/src/cli.js status",
    "flush":     "node packages/cli/src/cli.js flush"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "license": "MIT"
}
